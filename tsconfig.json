{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": [
      "jest"
    ],
    "ignoreDeprecations": "5.0",
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "App.tsx",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "Pods",
    "android",
    "ios",
    "dist",
    "build"
  ]
}